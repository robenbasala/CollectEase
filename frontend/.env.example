# Leave empty in local dev to use same-origin /api (Vite proxy → backend PORT, default 5000).
# Or set http://localhost:5000/api — in dev the client still uses the proxy when the host is localhost:5000.
VITE_API_BASE_URL=

# Must match backend DEFAULT_COMPANY_ID. Read via src/config/company.js
VITE_DEFAULT_COMPANY_ID=1
# Optional navbar label
VITE_COMPANY_NAME=Montium

# Microsoft Graph (payment reminders + inbox reply read from the signed-in user’s mailbox)
# Azure AD app: SPA platform, redirect URI must match VITE_MS_REDIRECT_URI (often http://localhost:5173).
# Delegated permissions: Mail.ReadWrite, User.Read (Mail.ReadWrite replaces Mail.Send; admin consent may be required).
VITE_MS_CLIENT_ID=
# Optional. Default: https://login.microsoftonline.com/common
# VITE_MS_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID
# Optional. Default: window origin (e.g. http://localhost:5173)
# VITE_MS_REDIRECT_URI=http://localhost:5173

# Firebase Authentication (email link, etc.) — Project settings → Your apps → SDK snippet
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=
