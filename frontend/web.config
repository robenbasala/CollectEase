<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ApiProxy" stopProcessing="true">
          <match url="api/auth/me" />
          <action type="Rewrite" url="http://127.0.0.1:5001/api/auth/me" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>