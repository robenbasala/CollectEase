PORT=5000
# Set development to see real SQL/connection errors in API JSON (do not use in public prod)
NODE_ENV=development
# Named instance: 172.202.115.36\SQLEXPRESS — no spaces around commas.
# Fixed TCP port only: DB_SERVER=172.202.115.36 and DB_PORT=49152 (omit instance).
DB_SERVER=localhost
# Optional; overrides comma in DB_SERVER when set
# DB_PORT=
# Database that contains table DataTbl (not the table name)
DB_DATABASE=YourDatabase
DB_USER=sa
DB_PASSWORD=YourStrongPassword
DB_ENCRYPT=true
# Either DB_TRUST_SERVER_CERTIFICATE or DB_TRUST_SERVER_CERT
DB_TRUST_SERVER_CERTIFICATE=true
# Optional (milliseconds). Defaults 30000 if unset.
# DB_CONNECTION_TIMEOUT_MS=30000
# DB_REQUEST_TIMEOUT_MS=30000

# Tenant id (must match dbo.Companies.Id). Read via src/config/activeCompany.js
DEFAULT_COMPANY_ID=1

# --- Firebase Admin SDK (verify ID tokens + custom claims on users; no Firestore) ---
# Service account JSON: Console → Project settings → Service accounts → save as secrets/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=

# Public URL of the SPA (password reset / invite continue). No trailing slash.
APP_PUBLIC_ORIGIN=http://localhost:5173

# --- Invite email ---
# If the admin is signed in with Microsoft in the app, invites are sent from their Outlook (Graph), same as payment reminders.
# Otherwise nodemailer uses SMTP when configured:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# Optional display name in invite template
# INVITE_APP_NAME=CollectEase
# Include password reset link in API JSON even when email sent (emergency / debugging only in production)
# INVITE_EXPOSE_LINK=true

# Optional extra super-admins (comma-separated). developer@collectease360.com is always super_admin in code.
# CT_SUPER_ADMIN_EMAILS=

# Bootstrap super list is defined in src/utils/email.js (DEFAULT_SUPER_ADMIN_EMAILS).
